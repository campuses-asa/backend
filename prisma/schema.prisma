generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String
  imageUrl       String?
  gpa            Decimal
  campusId       Int?
}

model Campus {
  id             Int      @id @default(autoincrement())
  name           String
  address        String
  imageUrl       String?
  description    String
}